# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side data scripts (importers, scorer, seed) write to RLS-protected
# tables, so they need the service role key, which bypasses RLS.
# Keep this secret — never expose it in the mobile app or commit it.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---------------------------------------------------------------------------
# Chewy
# ---------------------------------------------------------------------------
# Chewy affiliate product feed. If unset, import-chewy.js uses the local mock
# file at scripts/mock-chewy-data.json.
CHEWY_FEED_URL=your_chewy_affiliate_feed_url

# ---------------------------------------------------------------------------
# Walmart
# ---------------------------------------------------------------------------
WALMART_API_KEY=your_walmart_open_api_key
# Free instant approval at https://developer.walmart.com — click 'Get Started' under Open API

# ---------------------------------------------------------------------------
# Amazon Product Advertising API (PA-API v5)
# ---------------------------------------------------------------------------
AMAZON_ACCESS_KEY=your_amazon_pa_api_access_key
# Found in Associates Central → Tools → Product Advertising API
AMAZON_SECRET_KEY=your_amazon_pa_api_secret_key
# Same location as access key
AMAZON_PARTNER_TAG=your_associates_tag-20
# Your Associates store ID, format: yourname-20
AMAZON_REGION=us-east-1

# ---------------------------------------------------------------------------
# PetSmart (via Rainforest API)
# ---------------------------------------------------------------------------
RAINFOREST_API_KEY=your_rainforest_api_key
# Get key at https://rainforestapi.com — $0.002 per request, pay as you go

# ---------------------------------------------------------------------------
# Nightly refresh (Vercel serverless + pg_cron)
# ---------------------------------------------------------------------------
CRON_SECRET=generate_a_random_string_here
# Generate with: openssl rand -hex 32
