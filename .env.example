# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side data scripts (importers, scorer, seed) write to RLS-protected
# tables, so they need the service role key, which bypasses RLS.
# Keep this secret — never expose it in the mobile app or commit it.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---------------------------------------------------------------------------
# Chewy
# ---------------------------------------------------------------------------
# Chewy affiliate product feed. If unset, import-chewy.js uses the local mock
# file at scripts/mock-chewy-data.json.
CHEWY_FEED_URL=your_chewy_affiliate_feed_url

# ---------------------------------------------------------------------------
# Walmart
# ---------------------------------------------------------------------------
WALMART_API_KEY=your_walmart_open_api_key
# Free instant approval at https://developer.walmart.com — click 'Get Started' under Open API

# ---------------------------------------------------------------------------
# Amazon Product Advertising API (PA-API v5)
# ---------------------------------------------------------------------------
AMAZON_ACCESS_KEY=your_amazon_pa_api_access_key
# Found in Associates Central → Tools → Product Advertising API
AMAZON_SECRET_KEY=your_amazon_pa_api_secret_key
# Same location as access key
AMAZON_PARTNER_TAG=your_associates_tag-20
# Your Associates store ID, format: yourname-20
AMAZON_REGION=us-east-1

# ---------------------------------------------------------------------------
# Rainforest API (PetSmart importer + real-product seed)
# ---------------------------------------------------------------------------
RAINFOREST_API_KEY=your_rainforest_api_key
# Get key at https://rainforestapi.com — 1 credit per request

# scripts/seed-real-products.js pulls Amazon best sellers (2 credits total).
#   SEED_LIMIT = top-N products per category (default 20)
# SEED_LIMIT=20

# Secret guarding the browser-triggerable seed endpoint (api/seed-products.js).
# Send it as the `x-seed-secret` request header. Generate: openssl rand -hex 32
SEED_SECRET=generate_a_random_string_here

# ---------------------------------------------------------------------------
# Quality data (Open Pet Food Facts + openFDA)
# ---------------------------------------------------------------------------
# import-opff.js streams this gzipped, TAB-separated CSV export. Override only
# if you mirror it elsewhere. Optionally set OPFF_MAX_ROWS to scan just the
# first N rows on constrained machines.
OPFF_FEED_URL=https://static.openfoodfacts.org/data/en.openfoodfacts.org.products.csv.gz
# OPFF_MAX_ROWS=100000

# openFDA works unauthenticated; a free key raises the rate limit.
# Get one at https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# ---------------------------------------------------------------------------
# Nightly refresh (Vercel serverless + pg_cron)
# ---------------------------------------------------------------------------
CRON_SECRET=generate_a_random_string_here
# Generate with: openssl rand -hex 32
