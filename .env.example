# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side data scripts (import-chewy.js, score-quality.js) write to tables
# protected by RLS, so they need the service role key, which bypasses RLS.
# Keep this secret — never expose it in the mobile app or commit it.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Chewy affiliate product feed. If unset, import-chewy.js uses the local mock
# file at scripts/mock-chewy-data.json.
CHEWY_FEED_URL=your_chewy_affiliate_feed_url
